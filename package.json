{
  "name": "codium-ai-ide",
  "version": "1.0.0",
  "description": "VSCodium-like IDE with integrated AI assistant",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack --mode development --watch\" \"electron .\"",
    "build": "webpack --mode production && electron-builder",
    "install": "pnpm install",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rimraf node_modules && pnpm install"
  },
  "keywords": [
    "electron",
    "ide",
    "ai",
    "editor",
    "vscode"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.32",
    "ai": "^2.2.35",
    "dotenv": "^16.0.0",
    "electron-store": "^8.1.0",
    "monaco-editor": "^0.40.0",
    "openai": "^4.28.0",
    "split.js": "^1.6.5",
    "vscode-icons-js": "^11.6.1",
    "@vscode-elements/elements": "^1.14.0",
    "chokidar": "^3.5.3",
    "glob": "^10.3.10",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "build": {
    "appId": "com.codium.ai.ide",
    "productName": "Codium AI IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
} 